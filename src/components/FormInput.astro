---
export interface FormInputProps {
    id: string;
    label: string;
    type: string;
    value?: string | number;
    placeholder?: string;
    min?: number;
    max?: number;
    disabled?: boolean;
    note?: string;
    className?: string;
    step?: number;
}
---

<div class={Astro.props.className}>
    <label for={Astro.props.id} class=`block text-sm font-medium text-foreground ${Astro.props.type === "range" ? "mb-0" : "mb-2"}`>
        {Astro.props.label}
        {Astro.props.type === "range" && (
                <span id={`${Astro.props.id}-value`} class="text-xs text-muted-foreground mt-1">
                ({Astro.props.value})
            </span>
        )}
        {Astro.props.note && (
                <span class="text-xs text-muted-foreground mt-1">- {Astro.props.note}</span>
        )}
    </label>
    <input
            type={Astro.props.type}
            id={Astro.props.id}
            value={Astro.props.value}
            placeholder={Astro.props.placeholder}
            min={Astro.props.min}
            max={Astro.props.max}
            step={Astro.props.step}
            disabled={Astro.props.disabled}
            class={
                Astro.props.type === "color" ?
                    "w-20 h-10 rounded border border-border" :
                    "w-full px-4 py-2 bg-secondary border border-border rounded-lg text-foreground focus:outline-none focus:ring-2 focus:ring-primary disabled:opacity-50"
            }
    />
</div>

<script>
    // Add client-side script to handle range input value updates
    document.addEventListener('DOMContentLoaded', () => {
        const rangeInputs = document.querySelectorAll('input[type="range"]');
        rangeInputs.forEach(input => {
            const displayId = `${input.id}-value`;
            const displaySpan = document.getElementById(displayId);
            if (displaySpan) {
                const updateDisplay = () => {
                    displaySpan.textContent = `(${input?.value})`;
                };
                input.addEventListener('input', updateDisplay);
                updateDisplay(); // Initialize
            }
        });
    });
</script>