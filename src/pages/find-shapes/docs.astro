---
import Layout from '../../layouts/Layout.astro';
import ParameterDoc from '../../components/ParameterDoc.astro';
import BackgroundDocs from '../../components/BackgroundDocs.astro';
import GridDocs from '../../components/GridDocs.astro';
---

<Layout title="Find Shapes API Documentation - Neuro Exercises">
    <main class="min-h-screen bg-background">
        <!-- Header -->
        <header class="bg-gradient-to-r from-primary/10 to-secondary/10 border-b border-border py-12 px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-4xl">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-3 h-3 rounded-full bg-primary"></div>
                    <span class="text-sm font-medium text-primary">API Documentation</span>
                </div>
                <h1 class="text-4xl font-bold text-foreground mb-3">Find Shapes Configuration</h1>
                <p class="text-muted-foreground text-lg max-w-2xl">
                    Learn how to customize the Find Shapes minigame using URL parameters. Create custom shape-finding challenges with different movements, border behaviors, and target criteria.
                </p>

                <!-- Quick Navigation -->
                <div class="flex flex-wrap gap-2 mt-6">
                    <a href="#game-settings" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Game Settings
                    </a>
                    <a href="#color-shape-pools" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Color & Shape Pools
                    </a>
                    <a href="#movement-types" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Movement Types
                    </a>
                    <a href="#border-behaviors" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Border Behaviors
                    </a>
                    <a href="#target-criteria" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Target Criteria
                    </a>
                    <a href="#animation" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Animation
                    </a>
                    <a href="#appearance" class="text-sm bg-background hover:bg-secondary border border-border px-3 py-1.5 rounded-full transition-colors">
                        Appearance
                    </a>
                </div>
            </div>
        </header>

        <div class="py-12 px-4 sm:px-6 lg:px-8">
            <div class="mx-auto max-w-4xl">
                <!-- Introduction -->
                <div class="prose prose-lg max-w-none mb-12">
                    <p class="text-muted-foreground">
                        The Find Shapes minigame challenges users to find specific shapes among a moving field of colorful shapes.
                        This API allows you to customize every aspect of the game through URL parameters, from the number and size of shapes
                        to their movement patterns and what the user needs to find.
                    </p>
                </div>

                <div class="space-y-10">
                    <!-- Game Settings Section -->
                    <section id="game-settings">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Game Settings</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Core parameters that define the game structure and difficulty.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="numShapes"
                                    description="Total number of shapes displayed on the screen simultaneously."
                                    type="Number"
                                    defaultValue="20"
                                    min="5"
                                    max="50"
                                    examples={["/?numShapes=10", "/?numShapes=30", "/?numShapes=50"]}
                                    codeExample="?numShapes=25"
                            />

                            <ParameterDoc
                                    name="shapeSize"
                                    description="Size of each shape in pixels. Affects hit detection difficulty."
                                    type="Number"
                                    defaultValue="40"
                                    min="20"
                                    max="80"
                                    examples={["/?shapeSize=30", "/?shapeSize=50", "/?shapeSize=70"]}
                                    codeExample="?shapeSize=45"
                            />

                            <ParameterDoc
                                    name="targetCount"
                                    description="Specific number of shapes that match the target criteria. When omitted, the number is randomly distributed (1-3 shapes or 10-20% of total shapes)."
                                    type="Number"
                                    defaultValue="(random)"
                                    min="1"
                                    max="50"
                                    examples={["/?targetCount=5", "/?targetCount=10", "/?targetCount=1"]}
                                    codeExample="?target=red%20shapes&targetCount=3"
                            />

                            <ParameterDoc
                                    name="seed"
                                    description="Seed value for deterministic randomization. Using the same seed will generate identical shape positions, movements, and targets across runs."
                                    type="Number"
                                    defaultValue="(random)"
                                    examples={["/?seed=12345", "/?seed=1119806513", "/?seed=5789626"]}
                                    codeExample="?seed=42"
                            />

                            <ParameterDoc
                                    name="showTimer"
                                    description="Shows or hides the timer display during the game."
                                    type="Boolean"
                                    defaultValue="true"
                                    examples={["/?showTimer=false"]}
                                    codeExample="?showTimer=false"
                            />

                            <ParameterDoc
                                    name="hidePopupAll"
                                    description="When set to true, completely hides the results popup after test completion."
                                    type="Boolean"
                                    defaultValue="false"
                                    examples={["/?hidePopupAll=true"]}
                                    codeExample="?hidePopupAll=true"
                            />
                        </div>
                    </section>

                    <!-- Color & Shape Pools Section -->
                    <section id="color-shape-pools">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Color & Shape Pools</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Define which colors and shapes appear in the game.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="colors"
                                    description="Comma-separated list of colors that will appear in the game. At least one color must be selected."
                                    type="String"
                                    defaultValue="red,yellow,blue,green"
                                    examples={["/?colors=red,blue", "/?colors=purple,pink,orange", "/?colors=black,white,red"]}
                                    codeExample="?colors=red,green,blue,yellow,purple"
                            />

                            <div class="bg-card border border-border rounded-lg p-6 mb-4">
                                <h3 class="text-xl font-bold text-foreground mb-3">Available Colors</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-red-500/10 text-red-700 rounded-full text-sm">red</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-yellow-500/10 text-yellow-700 rounded-full text-sm">yellow</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-blue-500/10 text-blue-700 rounded-full text-sm">blue</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-green-500/10 text-green-700 rounded-full text-sm">green</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-gray-500/10 text-gray-700 rounded-full text-sm">white</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-gray-800/10 text-gray-900 rounded-full text-sm">black</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-purple-500/10 text-purple-700 rounded-full text-sm">purple</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-pink-500/10 text-pink-700 rounded-full text-sm">pink</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-orange-500/10 text-orange-700 rounded-full text-sm">orange</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-amber-800/10 text-amber-800 rounded-full text-sm">brown</span>
                                </div>
                            </div>

                            <ParameterDoc
                                    name="shapes"
                                    description="Comma-separated list of shapes that will appear in the game. At least one shape must be selected."
                                    type="String"
                                    defaultValue="square,triangle,circle,star"
                                    examples={["/?shapes=circle,square", "/?shapes=heart,star,diamond", "/?shapes=pentagon,hexagon,cross"]}
                                    codeExample="?shapes=circle,triangle,square,star,heart"
                            />

                            <div class="bg-card border border-border rounded-lg p-6">
                                <h3 class="text-xl font-bold text-foreground mb-3">Available Shapes</h3>
                                <div class="flex flex-wrap gap-3">
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">square</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">triangle</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">circle</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">star</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">rectangle</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">pentagon</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">hexagon</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">diamond</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">heart</span>
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-secondary rounded-full text-sm">cross</span>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Movement Types Section -->
                    <section id="movement-types">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Movement Types</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Different animation patterns that shapes follow across the screen.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="movement"
                                    description="Controls how shapes move across the screen. Each type creates a different visual pattern and difficulty level."
                                    type="String"
                                    defaultValue="linear"
                                    examples={["/?movement=swirly", "/?movement=bouncy", "/?movement=random"]}
                                    codeExample="?movement=wavy"
                            />

                            <!-- Movement Type Details -->
                            <div class="bg-card border border-border rounded-lg p-6">
                                <h3 class="text-xl font-bold text-foreground mb-3">Movement Type Details</h3>
                                <div class="grid gap-4">
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">linear</h4>
                                        <p class="text-sm text-muted-foreground">Shapes move in straight lines at constant speed.</p>
                                    </div>
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">swirly</h4>
                                        <p class="text-sm text-muted-foreground">Shapes follow circular or spiral paths, creating a swirling effect across the screen.</p>
                                    </div>
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">bouncy</h4>
                                        <p class="text-sm text-muted-foreground">Shapes oscillate vertically while moving horizontally, creating a bouncing effect.</p>
                                    </div>
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">wavy</h4>
                                        <p class="text-sm text-muted-foreground">Shapes follow a sine wave pattern, moving smoothly up and down while traveling horizontally.</p>
                                    </div>
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">spiral</h4>
                                        <p class="text-sm text-muted-foreground">Shapes move in gradually tightening spiral patterns, making them harder to track over time.</p>
                                    </div>
                                    <div class="pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">random</h4>
                                        <p class="text-sm text-muted-foreground">Shapes change direction randomly at intervals, creating unpredictable movement patterns.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Border Behaviors Section -->
                    <section id="border-behaviors">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Border Behaviors</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Controls how shapes interact with the screen boundaries.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="borderBehavior"
                                    description="Determines what happens when shapes reach the edge of the screen."
                                    type="String"
                                    defaultValue="collision"
                                    examples={["/?borderBehavior=wrap"]}
                                    codeExample="?borderBehavior=wrap"
                            />

                            <!-- Border Behavior Details -->
                            <div class="bg-card border border-border rounded-lg p-6">
                                <h3 class="text-xl font-bold text-foreground mb-3">Border Behavior Details</h3>
                                <div class="grid gap-4">
                                    <div class="border-b border-border pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">collision</h4>
                                        <p class="text-sm text-muted-foreground">Shapes bounce off walls with angle reflection. Speed is maintained, direction changes based on incident angle.</p>
                                    </div>
                                    <div class="pb-3">
                                        <h4 class="font-semibold text-foreground mb-1">wrap</h4>
                                        <p class="text-sm text-muted-foreground">Screen wrapping - shapes that move off one edge reappear on the opposite side, creating an infinite playfield.</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Target Criteria Section -->
                    <section id="target-criteria">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Target Criteria</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Defines what the user needs to find to complete the game.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="target"
                                    description="Specifies which shapes count as targets. Can filter by color, shape, or specific combinations."
                                    type="String"
                                    defaultValue="red shapes"
                                    examples={[
                                        "/?target=blue%20shapes",
                                        "/?target=circles",
                                        "/?target=all%20blue%20triangle"
                                    ]}
                                    codeExample="?target=green%20squares"
                            />

                            <!-- Target Criteria Details -->
                            <div class="bg-card border border-border rounded-lg p-6">
                                <h3 class="text-xl font-bold text-foreground mb-3">Target Criteria Options</h3>

                                <div class="mb-6">
                                    <h4 class="font-semibold text-foreground mb-2">By Color</h4>
                                    <p class="text-sm text-muted-foreground mb-2">Format: <code class="bg-secondary px-2 py-0.5 rounded">[color] shapes</code></p>
                                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm">
                                        <code class="bg-secondary px-2 py-1 rounded">red shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">blue shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">green shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">yellow shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">purple shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">pink shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">orange shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">brown shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">black shapes</code>
                                        <code class="bg-secondary px-2 py-1 rounded">white shapes</code>
                                    </div>
                                </div>

                                <div class="mb-6">
                                    <h4 class="font-semibold text-foreground mb-2">By Shape</h4>
                                    <p class="text-sm text-muted-foreground mb-2">Format: <code class="bg-secondary px-2 py-0.5 rounded">[shape]s</code> (plural)</p>
                                    <div class="grid grid-cols-2 md:grid-cols-3 gap-2 text-sm">
                                        <code class="bg-secondary px-2 py-1 rounded">circles</code>
                                        <code class="bg-secondary px-2 py-1 rounded">squares</code>
                                        <code class="bg-secondary px-2 py-1 rounded">triangles</code>
                                        <code class="bg-secondary px-2 py-1 rounded">rectangles</code>
                                        <code class="bg-secondary px-2 py-1 rounded">stars</code>
                                        <code class="bg-secondary px-2 py-1 rounded">pentagons</code>
                                        <code class="bg-secondary px-2 py-1 rounded">hexagons</code>
                                        <code class="bg-secondary px-2 py-1 rounded">diamonds</code>
                                        <code class="bg-secondary px-2 py-1 rounded">hearts</code>
                                        <code class="bg-secondary px-2 py-1 rounded">crosses</code>
                                    </div>
                                </div>

                                <div>
                                    <h4 class="font-semibold text-foreground mb-2">Color + Shape Combination</h4>
                                    <p class="text-sm text-muted-foreground mb-2">Format: <code class="bg-secondary px-2 py-0.5 rounded">all [color] [shape]</code></p>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
                                        <code class="bg-secondary px-2 py-1 rounded">all blue triangle</code>
                                        <code class="bg-secondary px-2 py-1 rounded">all red circle</code>
                                        <code class="bg-secondary px-2 py-1 rounded">all green square</code>
                                        <code class="bg-secondary px-2 py-1 rounded">all purple star</code>
                                        <code class="bg-secondary px-2 py-1 rounded">all pink heart</code>
                                    </div>
                                    <p class="text-xs text-muted-foreground mt-2">
                                        Note: Use URL encoding for spaces (%20) when passing these values in URLs.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Animation Parameters Section -->
                    <section id="animation">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Animation Parameters</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Fine-tune the movement behavior of shapes.</p>

                        <div class="space-y-6">
                            <ParameterDoc
                                    name="speed"
                                    description="Global speed multiplier for all movement types. Higher values make shapes move faster."
                                    type="Number"
                                    defaultValue="1.0"
                                    min="0.2"
                                    max="3.0"
                                    step="0.05"
                                    examples={["/?speed=0.5", "/?speed=2.0", "/?speed=3.0"]}
                                    codeExample="?speed=1.5"
                            />

                            <ParameterDoc
                                    name="swirlSpeed"
                                    description="Rotation speed for swirly movement type. Controls how fast shapes complete circular paths."
                                    type="Number"
                                    defaultValue="0.02"
                                    min="0.005"
                                    max="0.1"
                                    step="0.005"
                                    examples={["/?swirlSpeed=0.01", "/?swirlSpeed=0.05", "/?swirlSpeed=0.1"]}
                                    codeExample="?movement=swirly&swirlSpeed=0.03"
                            />

                            <ParameterDoc
                                    name="bounceAmplitude"
                                    description="Height of bounce movement in pixels. Higher values create more pronounced vertical motion."
                                    type="Number"
                                    defaultValue="50"
                                    min="10"
                                    max="150"
                                    step="5"
                                    examples={["/?bounceAmplitude=25", "/?bounceAmplitude=100", "/?bounceAmplitude=150"]}
                                    codeExample="?movement=bouncy&bounceAmplitude=75"
                            />

                            <ParameterDoc
                                    name="bounceFrequency"
                                    description="Speed of bounce oscillation. Higher values create faster bouncing."
                                    type="Number"
                                    defaultValue="0.005"
                                    min="0.001"
                                    max="0.02"
                                    step="0.001"
                                    examples={["/?bounceFrequency=0.002", "/?bounceFrequency=0.01", "/?bounceFrequency=0.02"]}
                                    codeExample="?movement=bouncy&bounceFrequency=0.008"
                            />
                        </div>
                    </section>

                    <!-- Appearance Section -->
                    <section id="appearance">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-2 h-8 bg-primary rounded-full"></div>
                            <h2 class="text-2xl font-bold text-foreground">Appearance</h2>
                        </div>
                        <p class="text-muted-foreground mb-6">Visual customization parameters.</p>

                        <div class="space-y-6">
                            <!-- Reusable Background Documentation -->
                            <BackgroundDocs />

                            <!-- Reusable Grid Documentation -->
                            <GridDocs />
                        </div>
                    </section>

                    <!-- Complete Examples -->
                    <section>
                        <div class="bg-primary/10 border border-primary rounded-lg p-6">
                            <h2 class="text-2xl font-bold text-foreground mb-3">Example Configurations</h2>

                            <div class="space-y-4">
                                <div>
                                    <h3 class="font-semibold text-foreground mb-2">Easy - Slow Moving Red Shapes</h3>
                                    <div class="bg-secondary rounded-lg p-3 overflow-x-auto relative group">
                                        <button class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-background/80 p-1 rounded text-xs"
                                                onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)">
                                            Copy URL
                                        </button>
                                        <code class="text-sm text-foreground font-mono">
                                            /find-shapes?numShapes=15&speed=0.5&movement=linear&target=red%20shapes
                                        </code>
                                    </div>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground mb-2">Medium - Swirly Shapes with Screen Wrapping</h3>
                                    <div class="bg-secondary rounded-lg p-3 overflow-x-auto relative group">
                                        <button class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-background/80 p-1 rounded text-xs"
                                                onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)">
                                            Copy URL
                                        </button>
                                        <code class="text-sm text-foreground font-mono">
                                            /find-shapes?numShapes=25&movement=swirly&borderBehavior=wrap&target=circles&swirlSpeed=0.03
                                        </code>
                                    </div>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground mb-2">Hard - Fast Random Movement, Find Specific Shape</h3>
                                    <div class="bg-secondary rounded-lg p-3 overflow-x-auto relative group">
                                        <button class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-background/80 p-1 rounded text-xs"
                                                onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)">
                                            Copy URL
                                        </button>
                                        <code class="text-sm text-foreground font-mono">
                                            /find-shapes?numShapes=40&speed=2.5&movement=random&borderBehavior=wrap&target=all%20blue%20triangle&shapeSize=35
                                        </code>
                                    </div>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground mb-2">Custom Color & Shape Pools</h3>
                                    <div class="bg-secondary rounded-lg p-3 overflow-x-auto relative group">
                                        <button class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-background/80 p-1 rounded text-xs"
                                                onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)">
                                            Copy URL
                                        </button>
                                        <code class="text-sm text-foreground font-mono text-xs">
                                            /find-shapes?numShapes=30&colors=purple,pink,orange&shapes=heart,star,diamond&target=all%20purple%20heart&targetCount=3
                                        </code>
                                    </div>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground mb-2">Complete Configuration with Background</h3>
                                    <div class="bg-secondary rounded-lg p-3 overflow-x-auto relative group">
                                        <button class="absolute top-2 right-2 opacity-0 group-hover:opacity-100 transition-opacity bg-background/80 p-1 rounded text-xs"
                                                onclick="navigator.clipboard.writeText(this.parentElement.querySelector('code').textContent)">
                                            Copy URL
                                        </button>
                                        <code class="text-sm text-foreground font-mono text-xs">
                                            /find-shapes?numShapes=30&shapeSize=45&movement=wavy&borderBehavior=wrap&target=purple%20shapes&targetCount=5&speed=1.2&bgColor=%23f0f0f0&gridEnabled=true&gridStyle=dotted&colors=purple,pink,orange,red,yellow,blue,green
                                        </code>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- Tips and Best Practices -->
                    <section>
                        <div class="bg-card border border-border rounded-lg p-6">
                            <h2 class="text-2xl font-bold text-foreground mb-3">Tips & Best Practices</h2>

                            <div class="space-y-3">
                                <div>
                                    <h3 class="font-semibold text-foreground">Difficulty Scaling</h3>
                                    <p class="text-sm text-muted-foreground">
                                        Increase difficulty by combining more shapes (numShapes), faster speeds, chaotic movement types (random),
                                        and specific target criteria. Use <code class="bg-secondary px-1 rounded">targetCount</code> to set a specific number of targets for consistent difficulty.
                                        Decrease difficulty with fewer shapes, slower speeds, and color-based targets.
                                    </p>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground">Performance Considerations</h3>
                                    <p class="text-sm text-muted-foreground">
                                        For optimal performance on lower-end devices, keep numShapes below 40 and shapeSize above 30.
                                        The random movement type requires more calculations than linear movement. Using fewer colors and shapes also improves performance.
                                    </p>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground">Accessibility</h3>
                                    <p class="text-sm text-muted-foreground">
                                        Consider using high-contrast color combinations and slower speeds for users with visual or motor challenges.
                                        The grid overlay can help with spatial tracking. Avoid using very similar colors together (e.g., red and orange, blue and purple).
                                    </p>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground">Target Count</h3>
                                    <p class="text-sm text-muted-foreground">
                                        Use <code class="bg-secondary px-1 rounded">targetCount</code> when you want consistent game length. Without it, the game generates
                                        1-3 target shapes for smaller games (less than 20 shapes) or 10-20% of total shapes for larger games.
                                    </p>
                                </div>

                                <div>
                                    <h3 class="font-semibold text-foreground">Reproducibility</h3>
                                    <p class="text-sm text-muted-foreground">
                                        Use the <code class="bg-secondary px-1 rounded">seed</code> parameter to reproduce identical games.
                                        This is useful for testing, benchmarking, or creating consistent difficulty across users.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <script>
        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
</Layout>