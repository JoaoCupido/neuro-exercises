---
import Layout from '../../layouts/Layout.astro';
import { Square, RectangleHorizontal, Circle, Triangle, Cross, Heart, Star, Pentagon, Hexagon, Diamond } from '@lucide/astro';
---

<Layout title="Wanted Shapes - Neuro Exercises" hideNavbar={true}>
    <main class="min-h-screen relative">
        <!-- Timer Display -->
        <div id="timer" class="z-50 fixed top-4 right-4 bg-card border border-border rounded-lg px-4 py-2 text-foreground font-medium shadow-lg w-36 text-center">
            0
        </div>

        <!-- Target Display -->
        <div id="targetDisplay" class="z-50 fixed top-4 left-4 bg-card border border-border rounded-lg px-4 py-2 shadow-lg justify-center">
            <div id="targetInfo" class="flex items-center gap-1 text-foreground font-medium"></div>
        </div>

        <!-- Results Popup -->
        <div id="popup" class="fixed inset-0 flex items-center justify-center bg-black/70 z-50 hidden">
            <div class="bg-card border border-border rounded-lg p-8 max-w-md mx-4 text-center">
                <h3 class="text-2xl font-bold text-foreground mb-4">Game Completed!</h3>
                <div class="space-y-3 mb-6">
                    <p id="popupTimer" class="text-foreground">Time: 0 seconds</p>
                    <p id="popupFound" class="text-foreground">Found: 0 / 0</p>
                    <p id="popupWrong" class="text-foreground">Wrong clicks: 0</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-3">
                    <button id="restartButton" class="bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors">
                        Restart Test
                    </button>
                    <a
                            href={(process.env.GITHUB_PAGES ? import.meta.env.BASE_URL : "/")}
                            class="bg-secondary text-secondary-foreground px-6 py-3 rounded-lg font-medium hover:bg-accent transition-colors text-center"
                    >
                        Back to Menu
                    </a>
                </div>
            </div>
        </div>

        <!-- Invalid Target Error Popup -->
        <div id="errorPopup" class="fixed inset-0 flex items-center justify-center bg-black/70 z-50 hidden">
            <div class="bg-card border border-border rounded-lg p-8 max-w-md mx-4 text-center">
                <h3 class="text-2xl font-bold text-destructive mb-4">Invalid Target!</h3>
                <p id="errorMessage" class="text-foreground mb-6"></p>
                <a href={(process.env.GITHUB_PAGES ? import.meta.env.BASE_URL : "/")} class="bg-primary text-primary-foreground px-6 py-3 rounded-lg font-medium hover:bg-primary/90 transition-colors inline-block">
                    Back to Menu
                </a>
            </div>
        </div>

        <!-- Canvas Container -->
        <div class="absolute inset-0">
            <canvas id="bgColorCanvas" class="absolute inset-0"></canvas>
            <canvas id="bgImageCanvas" class="absolute inset-0"></canvas>
            <canvas id="gridCanvas" class="absolute inset-0 pointer-events-none"></canvas>
            <canvas id="shapesCanvas" class="absolute inset-0"></canvas>
        </div>
    </main>

    <script>
        import { createIcons, Square, RectangleHorizontal, Circle, Triangle, Cross, Heart, Star, Pentagon, Hexagon, Diamond } from 'lucide';

        createIcons({
            icons: {
                Square,
                RectangleHorizontal,
                Circle,
                Triangle,
                Cross,
                Heart,
                Star,
                Pentagon,
                Hexagon,
                Diamond,
            }
        });
    </script>
    <script src="../../scripts/WantedShapesManager.js"></script>
</Layout>